{
  "version": 2,
  "installCommand": "npm ci --prefix Backend && npm ci --prefix Frontend/front-end && npm ci --prefix Admin/my-project",
  "buildCommand": "npm run build",
  "outputDirectory": "Frontend/front-end/dist",
  "functions": {
    "api/index.js": {
      "includeFiles": "Backend/src/Uploads/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/admin/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
